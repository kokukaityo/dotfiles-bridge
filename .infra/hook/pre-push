#!/usr/bin/env bash
# pre-push — push直前のガード。正本を汚さないための安全弁。
# 1) コンフリクトマーカーが残っているファイルがあれば中止
# 2) シークレットらしき内容（鍵・トークン）が含まれていれば中止
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../conf.sh"
cd "$DOTFILE"

fail() { echo "[pre-push] BLOCKED: $1"; exit 1; }

# 1) 未解決コンフリクトマーカー検知
if git grep -nE '^(<<<<<<<|=======|>>>>>>>)' -- . >/dev/null 2>&1; then
  git grep -nE '^(<<<<<<<|=======|>>>>>>>)' -- .
  fail "未解決のコンフリクトマーカーが残っています。解決してから push してください。"
fi

# 2) シークレット混入の簡易検知（誤爆時は環境変数 SKIP_SECRET_SCAN=1 で回避）
if [ "${SKIP_SECRET_SCAN:-0}" != "1" ]; then
  if git grep -nEi '(api[_-]?key|secret|password|token|BEGIN (RSA|OPENSSH) PRIVATE KEY)\s*[:=]' -- . \
      | grep -vE '(example|placeholder|<your|\$\{)' >/dev/null 2>&1; then
    echo "[pre-push] シークレットらしき記述を検出："
    git grep -nEi '(api[_-]?key|secret|password|token|BEGIN (RSA|OPENSSH) PRIVATE KEY)\s*[:=]' -- . \
      | grep -vE '(example|placeholder|<your|\$\{)' || true
    fail "実値の鍵/トークンが含まれていないか確認してください（誤検知なら SKIP_SECRET_SCAN=1 git push）。"
  fi
fi

echo "[pre-push] checks passed."
