#!/usr/bin/env bash
# post-merge — git pull / merge の後に走る。
# symlink を張り直して、新しい設定ファイルを取りこぼさない。
set -euo pipefail
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../conf.sh"

if command -v dotfiles >/dev/null 2>&1; then
    dotfiles link >/dev/null 2>&1 || \
        echo "[post-merge] dotfiles link failed; run 'dotfiles link' manually."
else
    bash "$DOTFILES_ENGINE_LIB/link.sh" >/dev/null 2>&1 || \
        echo "[post-merge] link.sh failed; run 'dotfiles link' manually."
fi
echo "[post-merge] symlink refreshed."
