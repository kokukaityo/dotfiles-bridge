#!/usr/bin/env bash
# post-merge — git pull / merge の後に走る。
# symlink を張り直して、新しい設定ファイルを取りこぼさない。
set -euo pipefail

if command -v dotfiles >/dev/null 2>&1; then
    if dotfiles link >/dev/null 2>&1; then
        echo "[post-merge] symlink refreshed."
    else
        echo "[post-merge] dotfiles link failed; run 'dotfiles link' manually."
    fi
else
    echo "[post-merge] dotfiles command not found; run 'dotfiles link' manually."
fi
