#!/usr/bin/env bash
# post-merge — git pull / merge の後に走る。
# 新しいSkillやcommandが増えていてもsymlinkを張り直して取りこぼさない。
set -euo pipefail
DOTFILES="${DOTFILES:-$HOME/dotfiles}"
if [ -f "$DOTFILES/install/link.sh" ]; then
  bash "$DOTFILES/install/link.sh" >/dev/null 2>&1 || \
    echo "[post-merge] link.sh failed; run 'bash install/link.sh' manually."
  echo "[post-merge] symlinks refreshed."
fi
